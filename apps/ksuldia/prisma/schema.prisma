// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  VIEWER
}

enum AttachmentSource {
  BACK_OFFICE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  UPLOAD
  DOWNLOAD
  EXPORT
  VERIFY
  REJECT
  REQUEST_REVISION
  LOGIN
  LOGOUT
  PASSWORD_RESET_ISSUED
  PASSWORD_RESET_USED
  PASSWORD_CHANGED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                String    @id @default(uuid(7))
  name              String
  email             String    @unique
  password          String
  role              UserRole  @default(VIEWER)
  isActive          Boolean   @default(true)
  createdById       String?
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  credentialSalt    String?
  image             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  passwordResetTokens       PasswordResetToken[]   @relation("PasswordResetTokenUser")
  issuedPasswordResetTokens PasswordResetToken[]   @relation("PasswordResetTokenIssuer")
  accountCredentials        AccountCredential[]

  @@map("users")
}

model PasswordResetToken {
  id         String    @id @default(uuid(7))
  userId     String
  issuedById String?
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user     User  @relation("PasswordResetTokenUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy User? @relation("PasswordResetTokenIssuer", fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([issuedById])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AuditLog {
  id            String            @id @default(uuid(7))
  actorId       String?
  actorRole     UserRole?
  action        AuditAction
  entityType    String
  entityId      String
  correlationId String?
  source        AttachmentSource?
  summary       String?
  metadata      Json?
  createdAt     DateTime          @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([correlationId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Low-level change log: every write (create/update/delete/upsert + *Many) that
// goes through the Prisma client is recorded here automatically by the client
// extension in src/lib/prisma.ts. Complements the human-readable AuditLog.
// operation/actorRole stored as String (no DB enum, per project convention).
model DataChangeLog {
  id            String   @id @default(uuid(7))
  model         String
  table         String?
  operation     String
  recordId      String?
  rowCount      Int?
  actorId       String?
  actorRole     String?
  correlationId String?
  payload       Json?
  before        Json?
  after         Json?
  diff          Json?
  createdAt     DateTime @default(now())

  @@index([model])
  @@index([recordId])
  @@index([actorId])
  @@index([correlationId])
  @@index([createdAt])
  @@map("data_change_logs")
}

// Vault akun aplikasi per-pengguna: menyimpan kredensial (username + password)
// untuk sistem-sistem yang dipakai pegawai (SIMRS, WiFi, presensi, dll.).
// Password dan catatan disimpan terenkripsi AES-256-GCM; kunci turunan dari
// CREDENTIAL_ENCRYPTION_KEY env var + userId + credentialSalt di User.
model AccountCredential {
  id          String    @id @default(uuid(7))
  userId      String
  name        String
  category    String    @default("lainnya")
  loginUrl    String?
  username    String?
  passwordEnc String    @db.Text
  notesEnc    String?   @db.Text
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@map("account_credentials")
}

// ---------------------------------------------------------------------------
// KSU Lidia Simpan Pinjam & Toko Models
// ---------------------------------------------------------------------------

enum SavingsType {
  POKOK
  WAJIB
  SUKARELA
}

enum SavingsTxType {
  DEPOSIT
  WITHDRAWAL
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
}

enum InstallmentStatus {
  UNPAID
  PAID
  LATE
}

enum ProductTxType {
  PURCHASE
  SALE
  ADJUSTMENT
}

model Member {
  id        String    @id @default(uuid(7))
  no        Int       @unique
  name      String
  isActive  Boolean   @default(true)
  phone     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  savingsAccounts     SavingsAccount[]
  savingsTransactions SavingsTransaction[]
  loans               Loan[]

  @@map("members")
}

model SavingsAccount {
  id        String      @id @default(uuid(7))
  memberId  String
  type      SavingsType
  balance   Decimal     @default(0) @db.Decimal(15, 2)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, type])
  @@index([memberId])
  @@map("savings_accounts")
}

model SavingsTransaction {
  id          String        @id @default(uuid(7))
  memberId    String
  type        SavingsTxType
  savingsType SavingsType
  amount      Decimal       @db.Decimal(15, 2)
  description String?
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([date])
  @@map("savings_transactions")
}

model Loan {
  id                String      @id @default(uuid(7))
  memberId          String
  amount            Decimal     @db.Decimal(15, 2)
  interestRate      Decimal     @db.Decimal(5, 2)
  tenor             Int
  provision         Decimal     @db.Decimal(15, 2)
  crk               Decimal     @db.Decimal(15, 2)
  receivedAmount    Decimal     @db.Decimal(15, 2)
  installmentAmount Decimal     @db.Decimal(15, 2)
  status            LoanStatus  @default(ACTIVE)
  dateDisbursed     DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  member       Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  installments LoanInstallment[]

  @@index([memberId])
  @@map("loans")
}

model LoanInstallment {
  id            String            @id @default(uuid(7))
  loanId        String
  monthNumber   Int
  principalPaid Decimal           @default(0) @db.Decimal(15, 2)
  interestPaid  Decimal           @default(0) @db.Decimal(15, 2)
  penaltyPaid   Decimal           @default(0) @db.Decimal(15, 2)
  totalPaid     Decimal           @default(0) @db.Decimal(15, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        InstallmentStatus @default(UNPAID)

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, monthNumber])
  @@index([loanId])
  @@map("loan_installments")
}

model Product {
  id            String   @id @default(uuid(7))
  code          String   @unique
  name          String
  category      String?
  stock         Int      @default(0)
  purchasePrice Decimal  @db.Decimal(15, 2)
  sellingPrice  Decimal  @db.Decimal(15, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactionItems ProductTransactionItem[]

  @@map("products")
}

model ProductTransaction {
  id          String        @id @default(uuid(7))
  type        ProductTxType
  totalAmount Decimal       @db.Decimal(15, 2)
  notes       String?
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())

  items ProductTransactionItem[]

  @@index([date])
  @@map("product_transactions")
}

model ProductTransactionItem {
  id            String             @id @default(uuid(7))
  transactionId String
  productId     String
  quantity      Int
  unitPrice     Decimal            @db.Decimal(15, 2)
  totalPrice    Decimal            @db.Decimal(15, 2)

  transaction ProductTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([productId])
  @@map("product_transaction_items")
}

