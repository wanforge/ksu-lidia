# NextAuth Configuration
NEXTAUTH_SECRET=development-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── Enkripsi Vault Akun Aplikasi ──────────────────────────────────────────
# Kunci master untuk mengenkripsi credential vault pegawai (AES-256-GCM).
# Wajib diisi di production. Gunakan: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=dev-credential-key-change-in-production-32b

# Google OAuth (optional - fill if using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAP_API_KEY=

# ─── CAPTCHA — aktifkan salah satu (atau biarkan kosong untuk test key di dev) ─
#
# Opsi A — Google reCAPTCHA v2 (diprioritaskan jika SITE_KEY diisi):
#   Daftar: https://www.google.com/recaptcha/admin  (pilih "reCAPTCHA v2 Checkbox")
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
#
# Opsi B — Cloudflare Turnstile (default fallback, test key otomatis di dev):
#   Daftar gratis: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Database
DATABASE_URL="mysql://root:lerd@localhost:3306/persona"

# Document storage
# Disk: "local" (default, dev) or "s3" (production, S3-compatible)
FILESYSTEM_DISK=local
# Local disk root (absolute path). Kosongkan untuk default ./storage relatif ke
# working directory. WAJIB diisi path absolut di server (systemd/pm2) agar upload
# tidak gagal saat working directory berbeda, mis. /var/www/persona-pro/apps/persona/storage
STORAGE_LOCAL_ROOT=

# S3-compatible storage (required when FILESYSTEM_DISK=s3)
# Works with AWS S3, rustfs, MinIO, idCloudHost, Cloudflare R2, etc.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_DEFAULT_REGION=us-east-1
# Server-side endpoint the app connects to (leave empty for AWS S3)
AWS_ENDPOINT=
# Public base URL of the bucket (not used for downloads; they stream via the
# authorized route). Kept for parity with the shared infra config.
AWS_URL=
# "true" for path-style providers (rustfs, MinIO)
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Branding / institution (all optional — the app runs zero-config) ─────────
# Override these to deploy the same build for any institution (instansi).
# Leave blank to use neutral defaults ("Persona", no organisation name).
NEXT_PUBLIC_APP_NAME=Persona
NEXT_PUBLIC_ORG_NAME=
NEXT_PUBLIC_ORG_SHORT_NAME=
NEXT_PUBLIC_ORG_EMAIL_DOMAIN=instansi.go.id
NEXT_PUBLIC_APP_TAGLINE=Sistem Informasi Manajemen Dokumen Kepegawaian
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_COPYRIGHT_HOLDER=

# ─── CAPTCHA — aktifkan salah satu (atau biarkan kosong untuk test key di dev) ─
#
# Opsi A — Google reCAPTCHA v3 invisible (diprioritaskan jika SITE_KEY diisi):
#   Daftar: https://www.google.com/recaptcha/admin  (pilih reCAPTCHA v3)
#   Package: react-google-recaptcha-v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.5
#
# Opsi B — Cloudflare Turnstile (default jika reCAPTCHA tidak dikonfigurasi):
#   Daftar gratis: https://dash.cloudflare.com -> Turnstile
#   Package: @marsidev/react-turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Seeding (dummy data via faker) ───────────────────────────────────────────
# Number of dummy employees to generate (default 2000).
SEED_EMPLOYEE_COUNT=2000
# Document type preset: "medis" (default, 20 RSUD/health types) or "generik".
SEED_DOC_PRESET=medis
# Initial admin account (defaults: admin@<ORG_EMAIL_DOMAIN> / Admin@1234).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
